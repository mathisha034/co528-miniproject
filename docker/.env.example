# ─────────────────────────────────────
# Common env vars (per service)
# Copy to .env and fill in values
# ─────────────────────────────────────

PORT=3001

# MongoDB
MONGO_URI=mongodb://localhost:27017/miniproject_db

# Redis
REDIS_URL=redis://localhost:6379

# Keycloak
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=miniproject
KEYCLOAK_CLIENT_ID=web-client

# MinIO (feed-service and research-service only)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=rootuser
MINIO_SECRET_KEY=rootpassword123
MINIO_BUCKET_NAME=miniproject
